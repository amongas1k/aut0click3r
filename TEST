	Pushed = function()
		local idx = tonumber(editIndexField.Value)
		if not idx or not clickQueue[idx] then return end
		local x = tonumber(editXField.Value)
		local y = tonumber(editYField.Value)
		local interval = tonumber(editIntervalField.Value)
		if x and y then
			clickQueue[idx].pos = Vector2.new(x, y)
			clickQueue[idx].interval = math.max(0, interval or 0)
			refreshClickList()
			editXField.Value = ""
			editYField.Value = ""
			editIntervalField.Value = ""
			editIndexField.Value = ""
		end
	end
})

actionRow:Right():Button({
	Label = "Delete",
	State = "Danger",
	Pushed = function()
		local idx = tonumber(editIndexField.Value)
		if idx and clickQueue[idx] then
			table.remove(clickQueue, idx)
			refreshClickList()
			editIndexField.Value = ""
		end
	end
})

