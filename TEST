-- Position Capture (Desktop: countdown, Mobile: tap anywhere)
local isCapturing = false
local captureStatusLabel
local touchConnection = nil

local captureRow = addClickForm:Row()
captureRow:Right():Button({
	Label = isTouchDevice and "Tap to capture position" or "Set Pos from Mouse (3s)",
	State = "Primary",
	Pushed = function()
		if isCapturing then return end
		isCapturing = true
		
		if isTouchDevice then
			captureStatusLabel.Text = "Tap anywhere on the screen..."
			touchConnection = game:GetService("UserInputService").TouchTap:Connect(function(input, processed)
				if processed then return end
				local pos = input.Position
				local winPos = window.__instance.AbsolutePosition
				local winSize = window.__instance.AbsoluteSize
				if pos.X >= winPos.X and pos.X <= winPos.X + winSize.X and
				   pos.Y >= winPos.Y and pos.Y <= winPos.Y + winSize.Y then
					return
				end
				xField.Value = tostring(math.floor(pos.X))
				yField.Value = tostring(math.floor(pos.Y))
				captureStatusLabel.Text = "Position captured!"
				isCapturing = false
				if touchConnection then touchConnection:Disconnect(); touchConnection = nil end
			end)
		else
			task.spawn(function()
				for i = 3, 1, -1 do
					captureStatusLabel.Text = "Capturing in " .. i .. "..."
					task.wait(1)
				end
				local mousePos = game:GetService("UserInputService"):GetMouseLocation()
				xField.Value = tostring(math.floor(mousePos.X))
				yField.Value = tostring(math.floor(mousePos.Y))
				captureStatusLabel.Text = "Position captured!"
				isCapturing = false
			end)
		end
	end
})

