function refreshClickList()
	for _, child in ipairs(scrollFrame:GetChildren()) do
		if child:IsA("TextLabel") then child:Destroy() end
	end
	for i, click in ipairs(clickQueue) do
		local label = Instance.new("TextLabel")
		label.Size = UDim2.new(1, 0, 0, 20)
		label.BackgroundTransparency = 1
		label.TextColor3 = Color3.new(1,1,1)
		label.Font = Enum.Font.Code
		label.TextSize = 14
		label.TextXAlignment = Enum.TextXAlignment.Left
		local intervalStr = click.interval > 0 and string.format("%.1fs", click.interval) or "global"
		label.Text = string.format("[%d] X:%.0f  Y:%.0f  (%s)", i, click.pos.X, click.pos.Y, intervalStr)
		label.Parent = scrollFrame
	end
	local totalHeight = #clickQueue * 22
	scrollFrame.CanvasSize = UDim2.new(0, 0, 0, math.max(totalHeight, isTouchDevice and 100 or 160))
end
refreshClickList()

