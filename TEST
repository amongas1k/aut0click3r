-- 6. Data Storage
local clickQueue = {}
local manualToggle = false
local cps = 10
local globalClickInterval = 1 / cps
local ignoreGUI = true       -- always on
local lastFreeClickTime = 0

-- Profile system
local PROFILE_FILE = "Aut0Cl1ck3r_Profiles.json"
local profiles = {}

local function loadProfileDB()
	local success, content = pcall(readfile, PROFILE_FILE)
	if success then
		pcall(function()
			profiles = game:GetService("HttpService"):JSONDecode(content)
		end)
	end
	if type(profiles) ~= "table" then profiles = {} end
end
local function saveProfileDB()
	local json = game:GetService("HttpService"):JSONEncode(profiles)
	writefile(PROFILE_FILE, json)
end

-- 7. Helper Functions
local function fireClick(position)
	if not position then return end
	game:GetService("VirtualInputManager"):SendMouseButtonEvent(
		position.X, position.Y, 0, true, game, 0
	)
	task.wait(math.random(30, 60) / 1000)
	game:GetService("VirtualInputManager"):SendMouseButtonEvent(
		position.X, position.Y, 0, false, game, 0
	)
end

local function isMouseOverGUI()
	if not ignoreGUI then return false end
	local mouse = game.Players.LocalPlayer:GetMouse()
	return mouse.Target ~= nil and mouse.Target:IsA("GuiObject") and mouse.Target.Visible
end

local function isActive()
	return manualToggle
end

local function processClicks()
	if not isActive() then return end
	if #clickQueue == 0 then return end
	local now = tick()
	for _, click in ipairs(clickQueue) do
		local interval = click.interval > 0 and click.interval or globalClickInterval
		if now - click.lastFire >= interval then
			fireClick(click.pos)
			click.lastFire = now
		end
	end
end

local function freeCursorClick()
	if not isActive() then return end
	if #clickQueue > 0 then return end
	if isMouseOverGUI() then return end
	local now = tick()
	if now - lastFreeClickTime >= globalClickInterval then
		local mousePos = game:GetService("UserInputService"):GetMouseLocation()
		fireClick(Vector2.new(mousePos.X, mousePos.Y))
		lastFreeClickTime = now
	end
end

