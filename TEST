-- Save Profile
settingsForm:Row():Right():Button({
	Label = "Save Profile",
	State = "Primary",
	Pushed = function()
		local name = profileNameField.Value
		if name == "" then return end
		local clicks = {}
		for _, click in ipairs(clickQueue) do
			table.insert(clicks, {
				pos = {X = click.pos.X, Y = click.pos.Y},
				interval = click.interval
			})
		end
		profiles[name] = {
			clicks = clicks,
			cps = cps,
			manualToggle = manualToggle,
			ignoreGUI = true
		}
		saveProfileDB()
		refreshProfileList()
		profileNameField.Value = ""
		selectedProfile = name
	end
})

-- Load Selected Profile
settingsForm:Row():Right():Button({
	Label = "Load Selected",
	State = "Primary",
	Pushed = function()
		local name = selectedProfile
		if not name or not profiles[name] then return end
		local data = profiles[name]
		for k in pairs(clickQueue) do clickQueue[k] = nil end
		for _, c in ipairs(data.clicks) do
			table.insert(clickQueue, {
				pos = Vector2.new(c.pos.X, c.pos.Y),
				interval = c.interval,
				lastFire = 0
			})
		end
		cps = data.cps or 10
		globalClickInterval = 1 / cps
		if cpsSlider then cpsSlider.Value = cps end
		manualToggle = data.manualToggle or false
		if autoToggle then autoToggle.Value = manualToggle end
		refreshClickList()
	end
})

-- Delete Selected Profile
settingsForm:Row():Right():Button({
	Label = "Delete Selected",
	State = "Danger",
	Pushed = function()
		local name = selectedProfile
		if not name or not profiles[name] then return end
		profiles[name] = nil
		saveProfileDB()
		refreshProfileList()
		profileNameField.Value = ""
		selectedProfile = nil
	end
})

